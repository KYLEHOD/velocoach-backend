# Strava API credentials — get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# Where your VeloCoach frontend lives
FRONTEND_URL=https://velocoach-ai.netlify.app

# The URL of THIS server once deployed (Railway will give you this)
BACKEND_URL=http://localhost:3000

# Port (Railway sets this automatically, 3000 for local dev)
PORT=3000
